{
  "name": "vscode-dji-pilot2-tools",
  "packageManager": "pnpm@10.11.0",
  "displayName": "WPML Viewer for DJI Pilot2",
  "description": "Developer tools for DJI Pilot 2 mission files (KMZ/WPML viewer and utilities)",
  "publisher": "shinyanakashima",
  "license": "MIT",
  "version": "0.1.0",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "DJI Pilot2",
    "KMZ",
    "WPML",
    "waypoint",
    "drone",
    "UAV",
    "geospatial"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/shinyanakashima/vscode-dji-pilot2-tools.git"
  },
  "main": "./out/extension.js",
  "contributes": {
    "customEditors": [
      {
        "viewType": "dji-pilot2-tools.kmzViewer",
        "displayName": "DJI KMZ Viewer",
        "selector": [
          {
            "filenamePattern": "*.kmz"
          }
        ],
        "priority": "default"
      }
    ],
    "commands": [
      {
        "command": "dji-pilot2-tools.openKmzViewer",
        "title": "DJI Pilot 2: Open KMZ Viewer"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "dji-pilot2-tools.openKmzViewer",
          "when": "resourceExtname == .kmz",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./ && node build-webview.mjs",
    "compile:ext": "tsc -p ./",
    "compile:webview": "node build-webview.mjs",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.25.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "@deck.gl/mapbox": "^9.2.11",
    "@types/maplibre-gl": "^1.14.0",
    "deck.gl": "^9.2.11",
    "jszip": "^3.10.1",
    "maplibre-gl": "^5.19.0",
    "preact": "^10.28.4",
    "preact-render-to-string": "^6.6.6"
  }
}
